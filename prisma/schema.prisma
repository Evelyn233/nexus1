generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                 @id @default(cuid())
  name                    String?
  email                   String?                @unique
  emailVerified           DateTime?
  password                String?
  image                   String?
  phone                   String?                @unique
  phoneVerified           Boolean                @default(false)
  gender                  String?
  birthDate               String?
  age                     Int?
  height                  String?
  weight                  String?
  location                String?
  personality             String?
  hairLength              String?
  selfMBTI                String?
  selfTraits              String?
  selfInterests           String?
  selfGoals               String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  profileData             String?
  profileSlug             String?                @unique
  // userType 暂不建列，存在 profileData.userType；有迁移后再加回： userType String? @default("person")
  accounts                Account[]
  chatSessions            ChatSession[]
  comments                Comment[]
  generatedImages         GeneratedImage[]
  profileMessagesSent     ProfileMessage[]       @relation("ProfileMessageFrom")
  profileMessagesReceived ProfileMessage[]       @relation("ProfileMessageTo")
  sessions                Session[]
  dailyQuotas             UserDailyQuota[]
  dailyQuestionResponses  UserDailyQuestionResponse[]
  generatedContents       UserGeneratedContent[]
  metadata                UserMetadata?
  payments                UserPayment[]
  wallet                  UserWallet?
  projectLikes            ProjectLike[]
  projectBookmarks        ProjectBookmark[]
  projectComments         ProjectComment[]

  @@map("users")
}

model UserMetadata {
  id                       String    @id @default(cuid())
  userId                   String    @unique
  zodiacSign               String?
  chineseZodiac            String?
  baziAnalysis             String?
  baziDayMaster            String?
  baziPattern              String?
  astrologicalProfile      String?
  ziweiAnalysis            String?
  deepAstrologicalAnalysis String?
  astroAnalysisDate        DateTime?
  coreTraits               String?
  communicationStyle       String?
  emotionalPattern         String?
  decisionStyle            String?
  stressResponse           String?
  interpersonalStrengths   String?
  interpersonalChallenges  String?
  socialEnergyPattern      String?
  aestheticPreferences     String?
  lifestyleHobbies         String?
  activityPreferences      String?
  fashionStyle             String?
  frequentLocations        String?
  favoriteVenues           String?
  careerAptitude           String?
  relationshipPattern      String?
  lifePhilosophy           String?
  luckyColors              String?
  luckyNumbers             String?
  userRawInputs            String?
  userMentionedKeywords    String?
  userMentionedLocations   String?
  userMentionedActivities  String?
  userMentionedFoods       String?
  userMentionedPeople      String?
  conversationInsights     String?
  behaviorPatterns         String?
  styleInsights            String?
  lastAnalyzed             DateTime  @default(now())
  analysisHistory          String?
  updateCount              Int       @default(0)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_metadata")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PhoneVerificationCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  type      String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expires])
  @@map("phone_verification_codes")
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expires])
  @@map("email_verification_codes")
}

model ChatSession {
  id            String   @id @default(cuid())
  userId        String
  title         String
  initialPrompt String
  messages      String
  answers       String
  questions     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_sessions")
}

model GeneratedImage {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  prompt    String
  imageUrl  String
  localPath String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("generated_images")
}

model UserGeneratedContent {
  id               String    @id @default(cuid())
  userId           String
  initialPrompt    String
  questions        String
  answers          String
  scenes           String
  storyNarrative   String?
  images           String
  imageCount       Int       @default(0)
  userSnapshot     String?
  metadataSnapshot String?
  status           String    @default("completed")
  tags             String?
  category         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  publishedAt      DateTime?
  sessionId        String?
  title            String?
  comments         Comment[]
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_generated_contents")
}

model ProfileMessage {
  id         String   @id @default(cuid())
  toUserId   String
  fromUserId String?
  text       String
  createdAt  DateTime @default(now())
  fromUser   User?    @relation("ProfileMessageFrom", fields: [fromUserId], references: [id])
  toUser     User     @relation("ProfileMessageTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([toUserId])
  @@index([createdAt])
  @@map("profile_messages")
}

model Comment {
  id        String               @id @default(cuid())
  contentId String
  userId    String
  text      String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  content   UserGeneratedContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model UserPayment {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  paymentId       String
  status          String   @default("pending")
  imagesPurchased Int      @default(5)
  paypalUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_payments")
}

model UserWallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Float    @default(0)
  totalSpent  Float    @default(0)
  totalEarned Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_wallets")
}

model UserDailyQuota {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime
  freeImagesUsed Int      @default(0)
  isNewUser      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("user_daily_quotas")
}

// 每日一问：用户回答 + 对问题的评价；同一天可多轮「继续生成问题并回答」
model UserDailyQuestionResponse {
  id           String   @id @default(cuid())
  userId       String
  questionDate DateTime // 问题所属日期
  questionText String   // 问题内容
  answer       String?  // 用户回答
  rating       String   // milder | sharper | keep | more_personal | other
  ratingNote   String?  // 选 other 时的补充说明
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionDate])
  @@index([userId, questionDate])
  @@map("user_daily_question_responses")
}

// 潜在合作：访客查看被访者 profile 时生成，自动入库
model CollaborationHint {
  id            String   @id @default(cuid())
  viewerUserId  String   // 访客
  targetUserId  String   // 被访者
  hint          String   // 生成的一句话
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([viewerUserId, targetUserId])
  @@index([viewerUserId])
  @@index([targetUserId])
  @@map("collaboration_hints")
}

// 应用配置（如 Profile 展示用户），供管理后台设置
model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

// 项目互动：点赞、收藏、评论
model ProjectLike {
  id              String   @id @default(cuid())
  userId          String
  targetUserId    String
  projectCreatedAt BigInt
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId, projectCreatedAt])
  @@index([userId])
  @@index([targetUserId, projectCreatedAt])
  @@map("project_likes")
}

model ProjectBookmark {
  id              String   @id @default(cuid())
  userId          String
  targetUserId    String
  projectCreatedAt BigInt
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId, projectCreatedAt])
  @@index([userId])
  @@index([targetUserId, projectCreatedAt])
  @@map("project_bookmarks")
}

model ProjectComment {
  id              String   @id @default(cuid())
  userId          String
  targetUserId    String
  projectCreatedAt BigInt
  text            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([targetUserId, projectCreatedAt])
  @@map("project_comments")
}
