# Copy this file to .env and fill in your values.
# Prisma (required for migrate and app)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Example for local PostgreSQL:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nexus?schema=public"

# Example for Neon / Supabase (replace with your connection string):
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ── Email (Resend) — 注册验证码 /api/auth/send-email-code 会用到 ─────────────
# 1. 注册 https://resend.com → API Keys 里创建密钥
# 2. 免费测试：可用发件人 onboarding@resend.dev，但只能发到你在 Resend 账号里登记过的邮箱
# 3. 正式上线：在 Resend 里添加并验证你自己的域名，再把下面改成 verify@你的域名.com
RESEND_API_KEY="re_xxxxxxxx"
# 可选：发件人邮箱（须是 Resend 里已验证的域名，或默认 onboarding@resend.dev）
RESEND_FROM_DOMAIN="onboarding@resend.dev"
# 可选：发件人显示名
# RESEND_FROM_NAME="Nexus"

# ── NextAuth + LinkedIn（社交登录创建账号）──────────────────────────────────
# NEXTAUTH_URL="https://your-domain.com"   # 生产填站点根 URL；本地可填 http://localhost:3000
# NEXTAUTH_SECRET="openssl rand -base64 32 生成"
# LinkedIn Developers → 创建 App → Auth 里添加回调 URL：
#   {NEXTAUTH_URL}/api/auth/callback/linkedin
# 产品勾选「Sign In with LinkedIn using OpenID Connect」，并申请 openid / profile / email 权限
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""
